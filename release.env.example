# Local secrets for deploy.sh (macOS release pipeline).
#
# Usage:
#   cp release.env.example release.env
#   # fill in real values
#   ./deploy.sh
#
# release.env is gitignored — never commit real values.
#
# The TAURI_SIGNING_* vars must ALSO be added as GitHub Actions repository
# secrets so the Windows workflow (.github/workflows/build-windows.yml) can
# sign the updater bundle and merge windows-x86_64 into latest.json.
#
# One-liner to mirror them from a filled-in release.env to GitHub Actions
# (requires gh CLI authenticated against the repo):
#
#   gh secret set TAURI_SIGNING_PRIVATE_KEY \
#     --body "$(grep -E '^TAURI_SIGNING_PRIVATE_KEY='            release.env | cut -d= -f2-)"
#   gh secret set TAURI_SIGNING_PRIVATE_KEY_PASSWORD \
#     --body "$(grep -E '^TAURI_SIGNING_PRIVATE_KEY_PASSWORD=' release.env | cut -d= -f2-)"
#
# Or via the GitHub UI:
#   Settings -> Secrets and variables -> Actions -> New repository secret
#
# ---------------------------------------------------------------------------
# macOS signing + notarization (Apple)
# ---------------------------------------------------------------------------

# Developer ID Application certificate name, exactly as it appears in Keychain
# Access. Example: 'Developer ID Application: Your Company (TEAMID)'.
export APPLE_SIGNING_IDENTITY=''

# Apple ID email used for notarization.
export APPLE_ID=''

# 10-char Team ID from your Apple Developer account.
export APPLE_TEAM_ID=''

# App-specific password generated at appleid.apple.com (NOT your normal Apple
# ID password). Format: xxxx-xxxx-xxxx-xxxx.
export APPLE_PASSWORD=''

# Optional: set only if your Apple ID belongs to multiple teams.
# export APPLE_PROVIDER_SHORT_NAME=''

# ---------------------------------------------------------------------------
# Tauri auto-updater signing (minisign)
# ---------------------------------------------------------------------------
# Generate once with:
#   npx @tauri-apps/cli signer generate -w ~/.tauri/mutaba3a.key
# Then paste the PRIVATE key contents (base64 blob starting with
# "dW50cnVzdGVk...") into TAURI_SIGNING_PRIVATE_KEY and the passphrase into
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD. Keep the public key in
# src-tauri/tauri.conf.json under plugins.updater.pubkey — both sides must
# match or every client will reject signed updates.
#
# Rotating this key invalidates auto-update for every already-installed copy
# of the app; plan rotations carefully.
#
# No `export` keyword here because deploy.sh reads them as shell variables and
# passes them to the tauri-cli via explicit --private-key / --password flags.

TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
